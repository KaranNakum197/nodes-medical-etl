# ──────────────────────────────────────────────────────────────
#  nodes-medical-etl  –  environment variable template
#  Copy this file to .env and fill in the values.
#  Never commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medical_etl

# ── VLM Engine (Qwen2-VL) ────────────────────────────────────
VLM_MODEL_ID=Qwen/Qwen2-VL-7B-Instruct
# ROCm exposes AMD GPUs as "cuda"; change to "cpu" for CPU-only testing
VLM_DEVICE=cuda

# ── Orchestration (CrewAI / LangChain) ───────────────────────
OPENAI_API_KEY=sk-...
FIREWORKS_API_KEY=your-fireworks-api-key-here
# Override to use a different LLM for orchestration decisions
ORCHESTRATOR_MODEL=fireworks_ai/accounts/fireworks/models/llama-v3p1-70b-instruct

# ── Backend API ───────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend ──────────────────────────────────────────────────
REACT_APP_API_BASE=http://localhost:8000

# --- Local PC .env ---

# 1. Point the agents' Vision Extraction HTTP requests to the Droplet
VLM_API_URL=http://<YOUR_DROPLET_IP>:8000/extract

# 2. Point the agents' PostgreSQL inserts to the Droplet DB
DATABASE_URL=postgresql://etl_user:etl_password@<YOUR_DROPLET_IP>:5432/medical_etl

# 3. Use Fireworks for the Agents' Brain (Llama 3)
FIREWORKS_API_KEY=your_fireworks_api_key
